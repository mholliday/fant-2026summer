# MongoDB connection URI (e.g. mongodb+srv://user:pass@cluster.mongodb.net/bonesdb)
BONES_DB_URI=mongodb://localhost:27017/bonesdb

# JWT secrets — use long random strings in production
ACCESS_TOKEN_SECRET=change_me_access_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret

# Server port
PORT=8000

# Set to "production" to enable secure cookies
NODE_ENV=development

# Admin credentials for seeding scripts
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123!
BONES_API_ADDRESS=http://localhost:8000/api/v2/
